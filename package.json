{
  "name": "aws-sdk-google-apps",
  "version": "2.0.1",
  "description": "Native support for the AWS SDK in Google Apps Script",
  "main": "index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node build.js",
    "deploy": "node build.js && clasp push",
    "format": "prettier {.,src,test}/*.js *.json *.md --write",
    "format:check": "prettier {.,src,test}/*.js *.json *.md --check",
    "lint": "eslint {.,src}/*.js",
    "sdk": "echo \"Building SDK for AWS Services: $npm_config_sdk\" && node aws-sdk-js/dist-tools/browser-builder.js $npm_config_sdk > src-sdk/aws-sdk.js",

    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dxdc/aws-sdk-google-apps.git"
  },
  "author": "Daniel Caspi <dan@element26.net>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dxdc/aws-sdk-google-apps/issues"
  },
  "homepage": "https://github.com/dxdc/aws-sdk-google-apps#readme",
  "devDependencies": {
    "@google/clasp": "^3.0.0",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-googleappsscript": "^1.0.5",
    "eslint-plugin-json": "^3.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "terser": "^5.37.0"
  }
}
